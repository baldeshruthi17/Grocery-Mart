rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================= GLOBAL HELPERS =================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role-based lookup from users profiles
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "baldeshruthi17@gmail.com" ||
        request.auth.token.email == "admin@jangaonmart.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Default deny security net
    match /{document=**} {
      allow read, write: if false;
    }

    // ================= USERS COLLECTION =================
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= PRODUCTS COLLECTION =================
    match /products/{productId} {
      allow read: if true; // Public catalog viewing
      allow write: if isAdmin(); // Admin-only product catalog changes
    }

    // ================= ORDERS COLLECTION =================
    match /orders/{orderId} {
      // Allow reading/listing own orders or admin/rider checks
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || resource.data.deliveryBoyId == request.auth.uid);
      allow list: if isSignedIn(); // Client retrieves and filters safely, rules protect detailed contents
      
      // Permit creation of own orders
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      
      // Update: Admin, Assigned Rider (for delivery updates), or Creator (for cancellation etc.)
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        resource.data.deliveryBoyId == request.auth.uid ||
        request.resource.data.deliveryBoyId == request.auth.uid
      );
      
      // Delete: admin-only
      allow delete: if isAdmin();
    }

    // ================= DELIVERY PARTNERS COLLECTION =================
    match /deliveryPartners/{partnerId} {
      allow read: if isSignedIn(); // Delivery partners/riders info viewing
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == partnerId);
    }
  }
}
